# Copy this file to `.env` (same directory) and fill in your real key.
# `.env` is gitignored — it will never be committed.
#
# Get a free key at https://console.groq.com/keys
# Without this set, the detector silently falls back to the deterministic
# rules floor (src/detector/classify.py) — the app still works, just without
# the LLM-backed classification/entity refinement (CLAUDE.md B8/B9).
GROQ_API_KEY=your_groq_api_key_here
